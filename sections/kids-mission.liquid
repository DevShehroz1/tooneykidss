{% style %}
  #kmiss-{{ section.id }} {
    display: block;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  #kmiss-{{ section.id }} .kmiss-wave {
    display: block;
    width: 100%;
    height: {{ section.settings.wave_height }}px;
    color: {{ section.settings.bg }};
    line-height: 0;
    pointer-events: none;
  }
  #kmiss-{{ section.id }} .kmiss-wave svg { width: 100%; height: 100%; display: block; }
  #kmiss-{{ section.id }} .kmiss-wave--top { margin-bottom: calc({{ section.settings.wave_gap }}px - 2px); }
  #kmiss-{{ section.id }} .kmiss-wave--bottom { transform: scaleY(-1); margin-top: {{ section.settings.wave_gap }}px; }
  #kmiss-{{ section.id }} .kmiss-body {
    background: {{ section.settings.bg }};
    padding-top: {{ section.settings.pad_top }}px;
    padding-bottom: {{ section.settings.pad_bottom }}px;
    text-align: center;
  }
  #kmiss-{{ section.id }} .kmiss-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }
  #kmiss-{{ section.id }} .kmiss-eyebrow {
    font-family: var(--font-heading-family, inherit);
    font-size: {{ section.settings.eyebrow_size }}px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin: 0 0 {{ section.settings.eyebrow_gap }}px;
  }
  #kmiss-{{ section.id }} .kmiss-heading {
    font-family: var(--font-heading-family, inherit);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.55;
    color: {{ section.settings.heading_color }};
    margin: 0 auto {{ section.settings.heading_gap }}px;
    font-weight: 500;
  }
  #kmiss-{{ section.id }} .kmiss-heading .kmiss-icon {
    display: inline-block;
    vertical-align: middle;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin: 0 {{ section.settings.icon_spacing }}px;
    position: relative;
    top: -0.1em;
  }
  #kmiss-{{ section.id }} .kmiss-heading .kmiss-icon img { width: 100%; height: 100%; display: block; object-fit: contain; }
  #kmiss-{{ section.id }} .kmiss-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ section.settings.btn_pad_y }}px {{ section.settings.btn_pad_x }}px;
    border-radius: 999px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_color }};
    font-family: var(--font-heading-family, inherit);
    font-size: {{ section.settings.btn_size }}px;
    font-weight: 600;
    text-decoration: none;
    transition: transform .2s ease, filter .2s ease;
  }
  #kmiss-{{ section.id }} .kmiss-btn:hover { transform: translateY(-1px); filter: brightness(1.05); }
  #kmiss-{{ section.id }} .kmiss-btn svg { width: 14px; height: 14px; }
  @media (max-width: 767px) {
    #kmiss-{{ section.id }} .kmiss-heading { font-size: {{ section.settings.heading_size_mb }}px; line-height: 1.5; }
    #kmiss-{{ section.id }} .kmiss-heading .kmiss-icon { width: {{ section.settings.icon_size_mb }}px; height: {{ section.settings.icon_size_mb }}px; margin: 0 6px; }
    #kmiss-{{ section.id }} .kmiss-body { padding-top: {{ section.settings.pad_top_mb }}px; padding-bottom: {{ section.settings.pad_bottom_mb }}px; }
  }
{% endstyle %}

{%- capture wave_svg -%}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 100" width="100%" height="100%" preserveAspectRatio="none" aria-hidden="true"><path d="M 0 50 Q 53.33 50 106.67 0 Q 160 50 213.33 50 Q 266.67 50 320 0 Q 373.33 50 426.67 50 Q 480 50 533.33 0 Q 586.67 50 640 50 Q 693.33 50 746.67 0 Q 800 50 853.33 50 Q 906.67 50 960 0 Q 1013.33 50 1066.67 50 Q 1120 50 1173.33 0 Q 1226.67 50 1280 50 Q 1333.33 50 1386.67 0 Q 1440 50 1493.33 50 L 1280 100 L 0 100 Z" fill="currentColor"></path></svg>
{%- endcapture -%}

<div id="kmiss-{{ section.id }}" class="kids-mission">
  {% if section.settings.show_top_wave %}
    <div class="kmiss-wave kmiss-wave--top" aria-hidden="true">{{ wave_svg }}</div>
  {% endif %}

  <div class="kmiss-body">
  <div class="kmiss-inner">
    {% if section.settings.eyebrow != blank %}
      <p class="kmiss-eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {%- liquid
      assign heading = section.settings.heading
      assign icon1_url = 'kids-mission-icon1.svg' | asset_url
      assign icon2_url = 'kids-mission-icon2.svg' | asset_url
      assign icon3_url = 'kids-mission-icon3.svg' | asset_url
      capture icon1
        echo '<span class="kmiss-icon"><img src="'
        echo icon1_url
        echo '" alt="" loading="lazy"></span>'
      endcapture
      capture icon2
        echo '<span class="kmiss-icon"><img src="'
        echo icon2_url
        echo '" alt="" loading="lazy"></span>'
      endcapture
      capture icon3
        echo '<span class="kmiss-icon"><img src="'
        echo icon3_url
        echo '" alt="" loading="lazy"></span>'
      endcapture
      assign heading = heading | replace: '[icon1]', icon1 | replace: '[icon2]', icon2 | replace: '[icon3]', icon3
    -%}
    <h2 class="kmiss-heading">{{ heading }}</h2>

    {% if section.settings.btn_label != blank and section.settings.btn_url != blank %}
      <a class="kmiss-btn" href="{{ section.settings.btn_url }}">
        {{ section.settings.btn_label }}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    {% endif %}
  </div>
  </div>

  {% if section.settings.show_bottom_wave %}
    <div class="kmiss-wave kmiss-wave--bottom" aria-hidden="true">{{ wave_svg }}</div>
  {% endif %}
</div>

