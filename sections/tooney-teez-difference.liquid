{%- assign removebg_img = product.metafields.custom.removebg -%}
{%- if removebg_img != blank -%}
<div class="ttz-diff-section">
  <h2 class="ttz-diff-heading">See The Tooney Teez Difference In Every Detail</h2>

  <div class="ttz-diff-wrap">
    <img
      class="ttz-diff-img"
      src="{{ removebg_img | image_url: width: 800 }}"
      alt="{{ product.title | escape }}"
      loading="lazy"
    >

    <div class="ttz-diff-card ttz-diff-card--left">
      <h3>Incredible Fabrics</h3>
      <p>Crafted from premium, natural fibres chosen for softness, breathability, and strength. Tooney Teez fabrics feel as good as they look, keeping kids comfy, cool, and always practical.</p>
    </div>

    <div class="ttz-diff-card ttz-diff-card--right">
      <h3>Made To Last</h3>
      <p>Timeless shapes. Quality construction. Every Tooney Teez piece is built to be loved, worn, and passed on. Because good design never dates and great clothes should outlast a season.</p>
    </div>
  </div>

  <div class="ttz-diff-mobile">
    <img
      class="ttz-diff-mobile-img"
      src="{{ removebg_img | image_url: width: 600 }}"
      alt="{{ product.title | escape }}"
      loading="lazy"
    >
    <div class="ttz-diff-carousel">
      <div class="ttz-diff-track">
        <div class="ttz-diff-slide">
          <h3>Incredible Fabrics</h3>
          <p>Crafted from premium, natural fibres chosen for softness, breathability, and strength. Tooney Teez fabrics feel as good as they look, keeping kids comfy, cool, and always practical.</p>
        </div>
        <div class="ttz-diff-slide">
          <h3>Made To Last</h3>
          <p>Timeless shapes. Quality construction. Every Tooney Teez piece is built to be loved, worn, and passed on. Because good design never dates and great clothes should outlast a season.</p>
        </div>
      </div>
      <div class="ttz-diff-dots">
        <span class="ttz-diff-dot ttz-diff-dot--active"></span>
        <span class="ttz-diff-dot"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .ttz-diff-section {
    padding: 60px 20px;
    background: #fff;
    text-align: center;
  }
  .ttz-diff-heading {
    font-size: 28px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 40px;
    line-height: 1.3;
  }

  /* Desktop */
  .ttz-diff-wrap {
    position: relative;
    width: {{ section.settings.image_size }}px;
    margin: 0 auto;
  }
  .ttz-diff-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    mix-blend-mode: multiply;
  }
  .ttz-diff-card {
    position: absolute;
    width: {{ section.settings.card_width }}px;
    background: #1e2d4a;
    color: #fff;
    border-radius: 12px;
    padding: {{ section.settings.card_padding_v }}px {{ section.settings.card_padding_h }}px;
    text-align: left;
  }
  .ttz-diff-card--left {
    left: {{ section.settings.left_card_x | times: 2 }}px;
    top: {{ section.settings.left_card_y | times: 2 }}px;
  }
  .ttz-diff-card--right {
    right: {{ section.settings.right_card_x | times: 2 }}px;
    bottom: {{ section.settings.right_card_y | times: 2 }}px;
  }
  .ttz-diff-card h3 {
    font-size: 15px;
    font-weight: 700;
    margin: 0 0 8px;
    color: #fff;
  }
  .ttz-diff-card p {
    font-size: 12px;
    line-height: 1.6;
    margin: 0;
    color: rgba(255,255,255,0.85);
  }

  /* Mobile */
  .ttz-diff-mobile { display: none; }

  @media (max-width: 768px) {
    .ttz-diff-section { padding: 40px 16px; }
    .ttz-diff-heading { font-size: 20px; margin-bottom: 24px; }
    .ttz-diff-wrap { display: none; }
    .ttz-diff-mobile { display: block; }

    .ttz-diff-mobile-img {
      width: 70%;
      max-width: 280px;
      height: auto;
      display: block;
      margin: 0 auto 24px;
      object-fit: contain;
      mix-blend-mode: multiply;
    }

    .ttz-diff-carousel {
      overflow: hidden;
      border-radius: 12px;
    }
    .ttz-diff-track {
      display: flex;
      transition: transform 0.5s ease;
    }
    .ttz-diff-slide {
      min-width: 100%;
      background: #1e2d4a;
      color: #fff;
      border-radius: 12px;
      padding: 20px 18px;
      text-align: left;
      box-sizing: border-box;
    }
    .ttz-diff-slide h3 {
      font-size: 15px;
      font-weight: 700;
      margin: 0 0 8px;
      color: #fff;
    }
    .ttz-diff-slide p {
      font-size: 12px;
      line-height: 1.6;
      margin: 0;
      color: rgba(255,255,255,0.85);
    }
    .ttz-diff-dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 14px;
    }
    .ttz-diff-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #ccc;
      display: inline-block;
      transition: background 0.3s;
    }
    .ttz-diff-dot--active {
      background: #1e2d4a;
    }
  }
</style>

<script>
  (function() {
    var track = document.querySelector('.ttz-diff-track');
    var dots  = document.querySelectorAll('.ttz-diff-dot');
    if (!track) return;
    var total   = track.children.length;
    var current = 0;

    function goTo(index) {
      current = index % total;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach(function(d, i) {
        d.classList.toggle('ttz-diff-dot--active', i === current);
      });
    }

    setInterval(function() { goTo(current + 1); }, 3000);
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Tooney Teez Difference",
  "class": "ttz-difference-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image width",
      "min": 300,
      "max": 900,
      "step": 10,
      "default": 600,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Cards size"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card width",
      "min": 140,
      "max": 380,
      "step": 10,
      "default": 240,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_padding_v",
      "label": "Card vertical padding",
      "min": 8,
      "max": 50,
      "step": 2,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_padding_h",
      "label": "Card horizontal padding",
      "min": 8,
      "max": 50,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Left card position"
    },
    {
      "type": "range",
      "id": "left_card_x",
      "label": "Left card — distance from left (×2 = actual px)",
      "min": -200,
      "max": 250,
      "step": 5,
      "default": -30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "left_card_y",
      "label": "Left card — distance from top (×2 = actual px)",
      "min": -200,
      "max": 300,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Right card position"
    },
    {
      "type": "range",
      "id": "right_card_x",
      "label": "Right card — distance from right (×2 = actual px)",
      "min": -200,
      "max": 250,
      "step": 5,
      "default": -30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "right_card_y",
      "label": "Right card — distance from bottom (×2 = actual px)",
      "min": -200,
      "max": 300,
      "step": 5,
      "default": 20,
      "unit": "px"
    }
  ]
}
{% endschema %}
