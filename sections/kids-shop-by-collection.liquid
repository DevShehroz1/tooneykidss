{% style %}
  #ksbc-{{ section.id }} {
    background: {{ section.settings.bg }};
    padding-top: {{ section.settings.pad_top }}px;
    padding-bottom: {{ section.settings.pad_bottom }}px;
  }
  #ksbc-{{ section.id }} .ksbc-wrap {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding-left: {{ section.settings.side_pad }}px;
    padding-right: {{ section.settings.side_pad }}px;
  }
  #ksbc-{{ section.id }} .ksbc-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 12px;
    margin-bottom: {{ section.settings.head_gap }}px;
  }
  #ksbc-{{ section.id }} .ksbc-head-left { flex: 1 1 auto; min-width: 0; text-align: center; }
  #ksbc-{{ section.id }} .ksbc-title {
    font-family: var(--font-heading-family, inherit);
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.1;
    margin: 0 0 8px;
    color: {{ section.settings.title_color }};
  }
  #ksbc-{{ section.id }} .ksbc-desc {
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    margin: 0;
  }
  #ksbc-{{ section.id }} .ksbc-shopall {
    flex: 0 0 auto;
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.link_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
  }
  #ksbc-{{ section.id }} .ksbc-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, minmax(0, 1fr));
    gap: {{ section.settings.grid_gap }}px;
  }
  #ksbc-{{ section.id }} .ksbc-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }
  #ksbc-{{ section.id }} .ksbc-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    transition: transform .3s ease;
  }
  #ksbc-{{ section.id }} .ksbc-card:hover .ksbc-img-wrap { transform: translateY(-4px); }
  #ksbc-{{ section.id }} .ksbc-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  #ksbc-{{ section.id }} .ksbc-label {
    font-family: var(--font-heading-family, inherit);
    font-size: {{ section.settings.label_size }}px;
    color: {{ section.settings.label_color }};
    margin: 0 0 4px;
    line-height: 1.2;
  }
  #ksbc-{{ section.id }} .ksbc-count {
    font-size: {{ section.settings.count_size }}px;
    color: {{ section.settings.count_color }};
    margin: 0;
    line-height: 1.2;
  }
  @media (max-width: 991px) {
    #ksbc-{{ section.id }} .ksbc-grid { grid-template-columns: repeat({{ section.settings.columns_tb }}, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    #ksbc-{{ section.id }} .ksbc-grid { grid-template-columns: repeat({{ section.settings.columns_mb }}, minmax(0, 1fr)); gap: 18px; }
    #ksbc-{{ section.id }} .ksbc-head { flex-direction: column; align-items: center; text-align: center; }
    #ksbc-{{ section.id }} .ksbc-title { font-size: {{ section.settings.title_size_mb }}px; }
  }
{% endstyle %}

<section id="ksbc-{{ section.id }}" class="kids-shop-by-collection">
  <div class="ksbc-wrap">
    <div class="ksbc-head">
      <div class="ksbc-head-left">
        {% if section.settings.title != blank %}
          <h2 class="ksbc-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="ksbc-desc">{{ section.settings.description }}</p>
        {% endif %}
      </div>
      {% if section.settings.shop_all_label != blank and section.settings.shop_all_url != blank %}
        <a class="ksbc-shopall" href="{{ section.settings.shop_all_url }}">{{ section.settings.shop_all_label }}</a>
      {% endif %}
    </div>

    <div class="ksbc-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign col = block.settings.collection
          assign custom_img = block.settings.image
          assign label_override = block.settings.label
          assign count_override = block.settings.count_text
          if col != blank
            assign display_label = label_override | default: col.title
            assign display_img = custom_img | default: col.image
            if col.image == blank and col.products.first
              assign display_img = custom_img | default: col.products.first.featured_image
            endif
            assign pcount = col.all_products_count
            if count_override != blank
              assign display_count = count_override
            else
              assign display_count = pcount | append: ' products'
            endif
            assign link_url = col.url
          else
            assign display_label = label_override
            assign display_img = custom_img
            assign display_count = count_override
            assign link_url = block.settings.link_url | default: '#'
          endif
        -%}
        <a class="ksbc-card" href="{{ link_url }}" {{ block.shopify_attributes }}>
          <div class="ksbc-img-wrap">
            {% if display_img != blank %}
              <img src="{{ display_img | image_url: width: 600 }}" alt="{{ display_label | escape }}" loading="lazy" width="600" height="600">
            {% endif %}
          </div>
          {% if display_label != blank %}
            <h3 class="ksbc-label">{{ display_label }}</h3>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by collection",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop by Collection"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Describe your section here"
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "Shop all label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "shop_all_url",
      "label": "Shop all link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 960,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "side_pad",
      "label": "Side padding",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "pad_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "pad_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "head_gap",
      "label": "Space below heading",
      "min": 8,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "columns_tb",
      "label": "Columns (tablet)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mb",
      "label": "Columns (mobile)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 18,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_size_mb",
      "label": "Title size (mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "desc_size",
      "label": "Description size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Card label size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "count_size",
      "label": "Product count size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Shop all link color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Card label color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "count_color",
      "label": "Product count color",
      "default": "#888888"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Overrides the collection image. Use transparent PNGs for shaped artwork."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label override",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "text",
          "id": "count_text",
          "label": "Count text override",
          "info": "Leave blank to show \"X products\""
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Custom link",
          "info": "Used only when no collection is selected"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Shop by collection",
      "category": "Homepage",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
