{% schema %}
{
  "name": "Announcement bar",
  "class": "t4-section t4-section-announcement-bar t4s_bk_flickity t4s_tp_cd",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "header",
      "content": "Scalloped kids style"
    },
    {
      "type": "checkbox",
      "id": "scallop_style",
      "label": "Enable scalloped style",
      "info": "Adds a dark top strip, side arrows and a scalloped bottom edge.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "top_strip_enabled",
      "label": "Show dark top strip",
      "default": true
    },
    {
      "type": "color",
      "id": "top_strip_bg",
      "label": "Top strip color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "top_strip_height",
      "label": "Top strip height",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "scallop_height",
      "label": "Scallop height",
      "min": 4,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "paragraph",
      "content": "In each block's content, insert these shortcodes to add an icon: [icon_package], [icon_truck], [icon_gift], [icon_heart]."
    },
    {
      "type": "select",
      "id": "effect",
      "label": "Effect slider",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "Fade"
        },
        {
          "value": "0",
          "label": "Slide"
        }
      ]
    },
    {
      "type": "range",
      "id": "au_time",
      "min": 0,
      "max": 30,
      "step": 0.5,
      "label": "Autoplay speed in second.",
      "info": "Set is '0' to disable autoplay.",
      "unit": "sec",
      "default": 3.5
    },
    {
      "type": "range",
      "id": "height",
      "label": "Min height",
      "default": 44,
      "min": 20,
      "max": 120,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "fontsize",
      "label": "Font size",
      "default": 14,
      "min": 12,
      "max": 18,
      "step": 0.5,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "cl",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Background color",
      "default": "#c7e0d3"
    },
    {
      "type": "range",
      "id": "bg_op",
      "label": "Background opacity",
      "default": 100,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "close",
      "label": "Button close",
      "default": "0",
      "options": [
        {
          "value": "0",
          "label": "Disable"
        },
        {
          "value": "1",
          "label": "Icon & text"
        },
        {
          "value": "2",
          "label": "Only icon"
        },
        {
          "value": "3",
          "label": "Only text"
        }
      ]
    },
    {
      "type": "color",
      "id": "cl_btn",
      "label": "Button close color",
      "default": "#fff"
    },
    {
      "type": "radio",
      "id": "version",
      "label": "Announcement version",
      "info": "If you apply any changes to your announcement settings or content you might want to force the announcement to all visitor who already close it again. In this case, you just need to change the announcement version.",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    },
    {
      "type": "range",
      "id": "date",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "day",
      "label": "Header banner expires",
      "info": "You will be able to specify when to expire the cookie. Once you click the \"CLOSE\" button",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "limit": 10,
      "settings": [
        {
          "type": "url",
          "id": "link",
          "label": "Banner link"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Banner content",
          "default": "<p>[icon_package] Delivery in 2-4 business days</p>",
          "info": "Place here text you want to see in the header banner. Shortcodes: [countdown], [icon_arrow], [icon_package], [icon_truck], [icon_gift], [icon_heart]"
        },
        {
          "type": "checkbox",
          "id": "adding_border",
          "label": "Adding a bottom border on link",
          "default": false
        },
        {
          "type": "text",
          "id": "countdown",
          "label": "Date countdown",
          "default": "2023/12/26",
          "info": "Use shortocdes: [countdown]. Countdown to the end sale date will be shown.( 2023/12/26 or 2023/12/26 20:00:30 )"
        },
        {
          "type": "text",
          "id": "txt_day",
          "label": "Text day countdown",
          "default": "days"
        },
        {
          "type": "range",
          "id": "dayx",
          "min": 0,
          "max": 100,
          "step": 1,
          "label": "Reset countdown every x days from an initial date.",
          "info": "Set is '0' to disable reset countdown.",
          "unit": "day",
          "default": 0
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      },
      {
        "type": "announcement"
      },
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}