{%- comment -%}
  Size Chart Snippet
  Usage: {% render 'size-chart', sc_type: sc_type, page_size: page_size, image: image, ck_s: ck_s %}
{%- endcomment -%}

<style>
  .t4s-btn__size-chart {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 20px;
    background: transparent;
    border: 1.5px solid currentColor;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none !important;
    color: inherit;
    opacity: 0.75;
    transition: opacity 0.2s ease, background 0.2s ease, color 0.2s ease;
    vertical-align: middle;
    line-height: 1.4;
  }
  .t4s-btn__size-chart:hover {
    opacity: 1;
    background: #121212;
    color: #fff !important;
    border-color: #121212;
  }
</style>

{%- if ck_s -%}
  {%- if sc_type == '1' and page_size != blank -%}
    <a class="t4s-ch t4s-btn__size-chart size-chart-link" data-no-instant rel="nofollow" href="{{ page_size.url }}" data-class="t4s-mfp-btn-close-inline" data-id="t4s-pr-popup__size-guide" data-storageid="{{ page_size.url }}" data-open-mfp-ajax data-style="max-width:950px" data-mfp-src="{{ page_size.url }}/?section_id=ajax_popup">
      {{ 'products.product.product_size_guide' | t | default: 'Size Guide' }}
    </a>
  {%- elsif sc_type == '2' and image != blank -%}
    <a class="t4s-ch t4s-btn__size-chart size-chart-link" data-no-instant rel="nofollow" href="{{ product.url }}" data-t4s-image-opend data-pswp-src="{{ image | image_url }}" data-pswp-w="{{ image.width }}" data-pswp-h="{{ image.height }}" data-pswp-class="pswp__size-guide">
      {{ 'products.product.product_size_guide' | t | default: 'Size Guide' }}
    </a>
  {%- endif -%}
{%- endif -%}
